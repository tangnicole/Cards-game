<!DOCTYPE html><html lang="en"><head>  <meta charset="UTF-8" />  <meta name="viewport" content="width=device-width, initial-scale=1" />  <title>Truth or Dare Competition</title>  <style>    body {      font-family: 'Comic Sans MS', cursive, sans-serif;      background: linear-gradient(to bottom right, #fbe6e3, #d4e1f0);      color: #333;      margin: 0;      padding: 20px;    }    header, section {      background: white;      border-radius: 10px;      padding: 20px;      margin-bottom: 15px;      box-shadow: 2px 4px 8px rgba(0,0,0,0.1);    }    h1, h2 {      color: #222;      text-align: center;    }    ul {      list-style-type: disc;      padding-left: 20px;    }    .rules {      background: #cfe3fc;      padding: 10px;      border-radius: 8px;      margin-top: 10px;      line-height: 1.5;    }    label {      font-weight: bold;    }    .questions, .tasks {      margin-top: 10px;    }    footer {      text-align: center;      font-style: italic;      margin-top: 30px;      color: #555;    }    /* Form styles */    form {      max-width: 400px;      margin: 0 auto 10px auto;      padding: 15px;      border: 1px solid #ccc;      border-radius: 8px;      background: #fafafa;    }    input[type="text"], input[type="email"] {      width: 100%;      padding: 8px;      margin: 8px 0 15px 0;      border: 1px solid #ccc;      border-radius: 4px;      box-sizing: border-box;      font-size: 1em;    }    input[type="submit"] {      background-color: #3a7bd5;      color: white;      border: none;      padding: 10px 15px;      border-radius: 5px;      cursor: pointer;      font-size: 1em;      width: 100%;    }    input[type="submit"]:hover {      background-color: #2a5cad;    }    /* Toggle link */    #toggleQuestions {      display: block;      width: max-content;      margin: 0 auto 15px auto;      text-decoration: underline;      color: #3a7bd5;      cursor: pointer;      font-weight: bold;      font-size: 1.1em;      text-align: center;    }    #questionsContent {      display: none;    }    .thank-you {      text-align: center;      font-weight: bold;      color: green;      margin-top: 10px;    }    .help-contact {      text-align: center;      font-size: 0.95em;      margin-bottom: 20px;      color: #444;    }  </style></head><body>
